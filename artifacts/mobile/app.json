{
  "expo": {
    "name": "StormRaven OS",
    "slug": "stormraven",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobile",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#050a12"
    },
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "backgroundColor": "#050a12"
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "21767c2c-d757-4153-a491-4db5b28663fa"
      }
    },
    "owner": "faithstormravens-team"
  }
}
